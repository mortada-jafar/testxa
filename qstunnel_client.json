{
    "log": {
        "loglevel": "debug",
        "access": "none"
    },
    "policy": {
        "levels": {
            "0": {
                "uplinkOnly": 0,
                "downlinkOnly": 0
            }
        }
    },
    "dns": {
        "servers": [
            "fakedns"
        ]
    },
    "inbounds": [
        {
            "tag": "mixed-in",
            "listen": "127.0.0.1",
            "port": 10808,
            "protocol": "mixed",
            "sniffing": {
                "enabled": true,
                "destOverride": [
                    "fakedns"
                ],
                "routeOnly": false
            },
            "settings": {
                "udp": true,
                "ip": "127.0.0.1"
            },
            "streamSettings": {
                "sockopt": {
                    "tcpKeepAliveInterval": 1,
                    "tcpKeepAliveIdle": 11
                }
            }
        }
    ],
    "outbounds": [
        {
            "tag": "proxy",
            "protocol": "vless",
            "settings": {
                "vnext": [
                    {
                        "address": "2.144.7.39",
                        "port": 2086,
                        "users": [
                            {
                                "id": "18947b04-60a2-4a39-b880-5fbab17b84b2",
                                "encryption": "none"
                            }
                        ]
                    }
                ]
            },
            "streamSettings": {
                "network": "qstunnel",
                "qstunnelSettings": {
                    "domain": "t.psss.ir",
                    "fakeSendIp": "146.70.104.252",
                    "fakeSendPort": 443,
                    "myPublicIp": "178.131.186.36",
                    "maxDomainLen": 60,
                    "maxSubLen": 50,
                    "retries": 1
                }
            }
        },
        {
            "protocol": "freedom",
            "tag": "direct"
        },
        {
            "protocol": "blackhole",
            "tag": "block"
        }
    ],
    "routing": {
        "domainStrategy": "AsIs",
        "rules": [
            {
                "type": "field",
                "ip": [
                    "geoip:private"
                ],
                "outboundTag": "direct"
            }
        ]
    }
}